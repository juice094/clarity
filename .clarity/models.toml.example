# Clarity Model Registry Configuration
# Copy this file to one of:
#   - ./.clarity/models.toml (project-local)
#   - ~/.config/clarity/models.toml (user-global)
#   - Or set CLARITY_MODELS_CONFIG to a custom path
#
# Reference: https://github.com/juice094/clarity

[providers.kimi-code]
protocol = "openai_chat"
base_url = "https://api.kimi.com/coding/v1"
api_key_env = "KIMI_CODE_API_KEY"

[providers.anthropic]
protocol = "anthropic_messages"
base_url = "https://api.anthropic.com"
api_key_env = "ANTHROPIC_AUTH_TOKEN"

[providers.deepseek]
protocol = "openai_chat"
base_url = "https://api.deepseek.com/v1"
api_key_env = "DEEPSEEK_API_KEY"

[providers.openai]
protocol = "openai_chat"
base_url = "https://api.openai.com/v1"
api_key_env = "OPENAI_API_KEY"

[providers.local]
protocol = "kalosm_local"
model_path = "C:\\Users\\22414\\Desktop\\model\\Qwen2.5-7B-Instruct.Q4_K_M.gguf"

[providers.ollama]
protocol = "ollama"
base_url = "http://localhost:11434"

[[models]]
alias = "kimi-k2"
provider = "kimi-code"
model_id = "kimi-k2-07132k"

[[models]]
alias = "claude-sonnet"
provider = "anthropic"
model_id = "claude-3-5-sonnet-20241022"

[[models]]
alias = "deepseek-chat"
provider = "deepseek"
model_id = "deepseek-chat"

[[models]]
alias = "gpt-4o"
provider = "openai"
model_id = "gpt-4o"

[[models]]
alias = "local-qwen"
provider = "local"
model_id = "Qwen2.5-7B-Instruct"

[[models]]
alias = "ollama-llama3"
provider = "ollama"
model_id = "llama3.1:8b"
