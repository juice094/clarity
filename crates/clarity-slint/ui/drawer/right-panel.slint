import { Theme } from "../theme.slint";
import { LucideIcon } from "../components/lucide-icon.slint";
import { IconSet } from "@lucide";

// 右侧面板占位。
// 用户已说明内容后续调整，当前仅实现容器与关闭按钮。
export component RightPanel {
    in property <bool> panel-visible: false;

    callback close-clicked();

    Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.surface-elevated;

        VerticalLayout {
            padding: 16px;
            spacing: 12px;

            HorizontalLayout {
                alignment: end;

                Rectangle {
                    width: 28px;
                    height: 28px;
                    border-radius: Theme.radius-full;
                    background: touch.has-hover ? Theme.surface-hover : transparent;

                    LucideIcon {
                        icon: IconSet.X;
                        size: 16px;
                        stroke: Theme.text-secondary;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }

                    touch := TouchArea {
                        clicked => { root.close-clicked(); }
                    }
                }
            }

            Text {
                text: "右侧面板";
                color: Theme.text-primary;
                font-size: Theme.font-headline;
                font-weight: 700;
            }

            Text {
                text: "历史 / Claw / Work 分组内容待设计。";
                color: Theme.text-tertiary;
                font-size: Theme.font-body;
                wrap: word-wrap;
            }
        }

        // 左侧分隔线
        Rectangle {
            x: 0px;
            width: 1px;
            height: parent.height;
            background: Theme.border;
        }
    }
}
