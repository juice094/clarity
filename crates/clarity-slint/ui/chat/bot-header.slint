import { Theme } from "../theme.slint";
import { LucideIcon } from "../components/lucide-icon.slint";
import { IconSet } from "@lucide";

export component BotHeader {
    in property <string> bot-name: "Bot";
    in property <bool> right-panel-visible: false;

    callback toggle-right-panel();

    Rectangle {
        height: Theme.bot-header-height;
        background: Theme.surface;

        HorizontalLayout {
            padding: 12px;
            spacing: 10px;

            // Bot 名称 + 状态点
            HorizontalLayout {
                spacing: 8px;
                alignment: start;

                LucideIcon {
                    icon: IconSet.Circle;
                    size: 8px;
                    stroke: Theme.success;
                    stroke-fill: Theme.success;
                    y: parent.height / 2 - self.height / 2;
                }

                Text {
                    text: root.bot-name;
                    color: Theme.text-primary;
                    font-size: Theme.font-headline;
                    font-weight: 600;
                }
            }

            // 右侧占位，把按钮推到最右
            Rectangle {
                horizontal-stretch: 1;
            }

            // 右侧操作按钮组（分享 / 历史 / 设置）
            for icon in [IconSet.Share2, IconSet.History, IconSet.Settings]: Rectangle {
                width: 28px;
                height: 28px;
                border-radius: Theme.radius-full;
                background: headerTouch.has-hover ? Theme.surface-hover : Theme.surface-elevated;

                LucideIcon {
                    icon: icon;
                    size: 16px;
                    stroke: Theme.text-secondary;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }

                headerTouch := TouchArea { }
            }

            // 右侧面板切换按钮
            Rectangle {
                width: 28px;
                height: 28px;
                border-radius: Theme.radius-full;
                background: root.right-panel-visible ? Theme.primary : Theme.surface-elevated;

                LucideIcon {
                    icon: IconSet.PanelRightOpen;
                    size: 16px;
                    stroke: root.right-panel-visible ? Theme.text-primary : Theme.text-secondary;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }

                TouchArea {
                    clicked => { root.toggle-right-panel(); }
                }
            }
        }

        // 底部分隔线
        Rectangle {
            x: 0px;
            y: parent.height - 1px;
            width: parent.width;
            height: 1px;
            background: Theme.border;
        }
    }
}
