import { Theme } from "../theme.slint";
import { BotHeader } from "./bot-header.slint";
import { InputBar } from "./input-bar.slint";
import { PretextLabel } from "../components/pretext-label.slint";

export component ChatArea {
    in property <string> bot-name: "Bot";
    in-out property <string> input-text: "";
    in property <bool> right-panel-visible: false;

    callback toggle-right-panel();
    pure callback input-text-changed(string);
    pure callback send-clicked();
    pure callback upload-clicked();
    pure callback pretext-render(string, length, string, color) -> image;

    Rectangle {
        background: Theme.surface;

        VerticalLayout {
            BotHeader {
                bot-name: root.bot-name;
                right-panel-visible: root.right-panel-visible;
                toggle-right-panel => { root.toggle-right-panel(); }
            }

            // 消息列表占位
            Rectangle {
                vertical-stretch: 1;

                VerticalLayout {
                    alignment: center;

                    Text {
                        text: "Clarity";
                        color: Theme.text-tertiary;
                        font-size: Theme.font-title;
                        font-weight: 700;
                        horizontal-alignment: center;
                    }

                    PretextLabel {
                        text: "（阶段 2 接入真实消息列表）";
                        font: "14px Microsoft YaHei UI";
                        requested-width: 260px;
                        text-color: Theme.text-tertiary;
                        render-text(text, width, font, color) => {
                            root.pretext-render(text, width, font, color);
                        }
                    }
                }
            }

            InputBar {
                text <=> root.input-text;
                text-changed(t) => { root.input-text-changed(t); }
                send-clicked => { root.send-clicked(); }
                upload-clicked => { root.upload-clicked(); }
            }
        }
    }
}
