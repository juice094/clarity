// 设计 Token：颜色、字号、间距
export global Theme {
    // 主色板
    in-out property <color> primary: #3b82f6;
    in-out property <color> primary-hover: #2563eb;
    in-out property <color> surface: #09090b;
    in-out property <color> surface-elevated: #18181b;
    in-out property <color> surface-hover: #27272a;
    in-out property <color> border: #27272a;
    in-out property <color> text-primary: #fafafa;
    in-out property <color> text-secondary: #a1a1aa;
    in-out property <color> text-tertiary: #71717a;
    in-out property <color> success: #4ade80;
    in-out property <color> warning: #facc15;
    in-out property <color> error: #ef4444;

    // 尺寸
    in-out property <length> sidebar-width: 260px;
    in-out property <length> sidebar-collapsed-width: 48px;
    in-out property <length> right-panel-width: 320px;
    in-out property <length> title-bar-height: 40px;
    in-out property <length> bot-header-height: 48px;
    in-out property <length> input-bar-height: 64px;

    // 字号阶梯
    in-out property <length> font-title: 24px;
    in-out property <length> font-headline: 16px;
    in-out property <length> font-body: 14px;
    in-out property <length> font-caption: 12px;

    // 圆角
    in-out property <length> radius-sm: 4px;
    in-out property <length> radius-md: 8px;
    in-out property <length> radius-lg: 12px;
    in-out property <length> radius-full: 999px;
}
