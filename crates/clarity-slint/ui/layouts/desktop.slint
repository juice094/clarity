import { Sidebar } from "../navigation/sidebar.slint";
import { ChatArea } from "../chat/chat-area.slint";
import { StatusPanel } from "../status/status-panel.slint";
import { SessionStatus } from "../models.slint";

export component DesktopLayout {
    in property <[string]> roles: [];
    in property <string> active-role: "";
    in property <[SessionStatus]> sessions: [];
    in property <string> gateway-status: "Offline";
    in property <string> chat-title: "会话";

    pure callback role-clicked(string);
    pure callback session-clicked(SessionStatus);

    HorizontalLayout {
        Sidebar {
            roles: root.roles;
            active-role: root.active-role;
            role-clicked(role) => { root.role-clicked(role); }
        }

        ChatArea {
            title: root.chat-title;
        }

        StatusPanel {
            sessions: root.sessions;
            gateway-status: root.gateway-status;
            session-clicked(session) => { root.session-clicked(session); }
        }
    }
}
