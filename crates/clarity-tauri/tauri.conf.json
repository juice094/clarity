{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "frontend/dist"
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "category": "DeveloperTool",
    "copyright": "© 2026 Clarity Contributors",
    "shortDescription": "Rust AI Agent runtime for developers",
    "longDescription": "Clarity is a Rust-based AI Agent framework with Desktop GUI, featuring Plan Mode, parallel subagents, local LLM inference, and deep memory systems.",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  },
  "productName": "Clarity",
  "version": "0.2.1",
  "identifier": "dev.clarity.app",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxNkUzOEFDMUQwQUIxRDYKUldUV3NRb2RyRGh1Y2NoN1h0aFNLaCtWdlJzVkN1amUvajdtK2FzMTBrckJJVEJhaTJ6cmdsbmoK",
      "endpoints": [
        "https://github.com/juice094/clarity/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "windows": [
      {
        "title": "Clarity",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ]
  }
}
