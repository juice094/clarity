# Auto-detect text files and normalize line endings
* text=auto

# Source code: enforce LF
*.rs text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf

# Windows-specific scripts can keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files: do not modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.msi binary
*.db binary
